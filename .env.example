# Copy to `.env` and adjust, then `docker compose up -d --build`.

# Host port for the web dashboard (container always listens on 8080 internally).
FH6_HTTP_PORT=8080

# Host UDP port for Forza telemetry (container always listens on 20440 internally).
FH6_UDP_PORT=20440

# Extra flags passed to fh6-tel-serve. On a server, set an auth token so the
# dashboard requires login. Example:
#   FH6_EXTRA_ARGS=--auth-token change-me-to-a-secret
FH6_EXTRA_ARGS=
